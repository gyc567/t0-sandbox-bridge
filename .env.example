# T-0 Provider Service (provider -> agtpay REST direction)
# When both are set, HttpT0Client pushes published quotes to the real
# ngrok / REST endpoint. Otherwise MockT0Client is used in-memory.
T0_NGROK_URL=
T0_API_KEY=

# t-0 Network public key (used by the /api/v1/t0/provider/* RPC handlers
# to verify the signature on inbound requests).
T0_NETWORK_PUBLIC_KEY=

# OFI Quote Client (OFI -> agtpay /api/v1/quotes/network direction)
# "http"  -> real agtpay backend
# "mock"  -> reuse the in-memory provider snapshot (dev/CI default)
T0_QUOTE_CLIENT_MODE=mock

# When T0_QUOTE_CLIENT_MODE=http, point at the agtpay backend.
# Token must be one of PROVIDER_API_KEYS allowed on the server side.
T0_OFI_API_BASE_URL=https://api.agtpay.xyz
T0_OFI_API_KEY=

# HTTP client timeout in milliseconds (default 5000).
T0_OFI_TIMEOUT_MS=5000

# Default payment method for OFI quotes (UI does not expose this).
# See t-0 enum: PAYMENT_METHOD_TYPE_SEPA / PAYMENT_METHOD_TYPE_SWIFT / ...
T0_OFI_PAYMENT_METHOD=PAYMENT_METHOD_TYPE_SEPA
